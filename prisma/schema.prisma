generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id             BigInt   @id @default(autoincrement())
  source         String
  originalId     String   @map("original_id")
  contentText    String?  @map("content_text")
  translatedText String?  @map("translated_text")
  originalUrl    String?  @map("original_url")
  screenshotUrl  String?  @map("screenshot_url")
  status         String   @default("pending")
  failCount      Int      @default(0) @map("fail_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([source, originalId])
  @@index([source, originalId], map: "idx_posts_source_original_id")
  @@index([status], map: "idx_posts_status")
  @@index([createdAt(sort: Desc)], map: "idx_posts_created_at")
  @@map("posts")
}
